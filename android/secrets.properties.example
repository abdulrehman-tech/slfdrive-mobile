# Copy this file to `secrets.properties` (same directory) and fill in real values.
# `secrets.properties` is gitignored and is read at Gradle configure time from
# `android/app/build.gradle.kts`, then injected into AndroidManifest.xml as
# manifest placeholders (e.g. ${MAPS_API_KEY}).
MAPS_API_KEY=YOUR_ANDROID_MAPS_API_KEY_HERE
