// Copy this file to `Secrets.xcconfig` (same directory) and fill in real values.
// `Secrets.xcconfig` is gitignored and is included from `Debug.xcconfig` and
// `Release.xcconfig`. The value is surfaced to `Info.plist` under the
// `GMSApiKey` key and read by `AppDelegate.swift` at runtime.
MAPS_API_KEY = YOUR_IOS_MAPS_API_KEY_HERE
